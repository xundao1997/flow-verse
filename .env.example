# Root-level variables used by docker-compose.yml.
# This compose file expects MySQL and Redis to be provided externally.

# Aliyun ACR namespace
REGISTRY_NAMESPACE=your-namespace

# Backend app runtime
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Shanghai

# MySQL connection
MYSQL_HOST=mysql.example.internal
MYSQL_PORT=3306
MYSQL_USER=verse_user
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=verse_agent

# Redis connection
REDIS_HOST=redis.example.internal
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_DB=0

# Celery runtime
CELERY_BROKER_URL=redis://:change_me@redis.example.internal:6379/1
CELERY_RESULT_BACKEND=redis://:change_me@redis.example.internal:6379/2
