APP_NAME=Verse Agent
APP_ENV=local
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=false
APP_DEBUG=false
APP_TIMEZONE=UTC
API_V1_PREFIX=/api/v1

LOGGING__LEVEL=INFO
LOGGING__DIRECTORY=logs
LOGGING__FILE_NAME=verse-agent.log
LOGGING__ROTATION=10 MB
LOGGING__RETENTION=14 days
LOGGING__COMPRESSION=zip
LOGGING__SERIALIZE=false

DATABASE__HOST=127.0.0.1
DATABASE__PORT=3306
DATABASE__USER=verse_agent
DATABASE__PASSWORD=change_me
DATABASE__NAME=verse_agent
DATABASE__ECHO=false
DATABASE__POOL_PRE_PING=true
DATABASE__POOL_RECYCLE=1800
DATABASE__POOL_SIZE=10
DATABASE__MAX_OVERFLOW=10
DATABASE__CONNECT_TIMEOUT=10

REDIS__HOST=127.0.0.1
REDIS__PORT=6379
REDIS__DB=0
REDIS__USERNAME=
REDIS__PASSWORD=
REDIS__DECODE_RESPONSES=true
REDIS__SOCKET_TIMEOUT=5
REDIS__HEALTH_CHECK_INTERVAL=30

CELERY__BROKER_URL=redis://127.0.0.1:6379/1
CELERY__RESULT_BACKEND=redis://127.0.0.1:6379/2
CELERY__TASK_DEFAULT_QUEUE=verse-agent.default
CELERY__TASK_TRACK_STARTED=true
CELERY__TASK_TIME_LIMIT=300
CELERY__TASK_SOFT_TIME_LIMIT=240
CELERY__RESULT_EXPIRES=3600
CELERY__TASK_ALWAYS_EAGER=false
